aws_iam_role_arn_state_manager = "${state_manager_role_arn}"
aws_iam_role_arn_admin         = "${admin_role_arn}"
aws_iam_role_arn_github        = "${github_role_arn}"
default_tags = {
  "created_by" : "${gh_org_name}/${repo_name}"
}

aws_default_region = "${region}"
